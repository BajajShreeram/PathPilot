# PathPilot Backend Environment Variables

# Mesh API Configuration
MESH_API_KEY=your_mesh_api_key_here
MESH_MODEL=openai/gpt-4o

# Frontend URL for CORS (deployed frontend)
# Example: https://pathpilot.vercel.app
FRONTEND_URL=

# Supabase Configuration (when integrating)
# SUPABASE_URL=your_supabase_url
# SUPABASE_KEY=your_supabase_key
# SUPABASE_JWT_SECRET=your_jwt_secret
